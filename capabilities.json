{
  "dataRoles": [
    {
      "displayName": "Category",
      "name": "Category",
      "kind": "Grouping",
      "description": "Category for the Pareto chart (e.g., Defect Type).",
      "preferredTypes": [
        {
          "text": true
        }
      ]
    },
    {
      "displayName": "Measure",
      "name": "Measure",
      "kind": "Measure",
      "description": "Measure to analyze (e.g., Count of Defects).",
      "preferredTypes": [
        {
          "numeric": true
        }
      ]
    },
    {
      "displayName": "Tooltip",
      "name": "Tooltip",
      "kind": "Measure",
      "description": "Additional measures to show in the tooltip."
    },
    {
      "displayName": "Legend",
      "name": "Legend",
      "kind": "Grouping",
      "description": "Optional grouping for legend segmentation."
    },
    {
      "displayName": "Secondary Measure",
      "name": "SecondaryMeasure",
      "kind": "Measure",
      "description": "Optional secondary measure for dual-axis analysis."
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "Category": {
            "max": 1
          },
          "Measure": {
            "max": 1
          },
          "Legend": {
            "max": 1
          },
          "SecondaryMeasure": {
            "max": 1
          }
        }
      ],
      "categorical": {
        "categories": {
          "for": {
            "in": "Category"
          },
          "dataReductionAlgorithm": {
            "top": {
              "count": 30000
            }
          }
        },
        "values": {
          "select": [
            {
              "bind": {
                "to": "Measure"
              }
            },
            {
              "bind": {
                "to": "SecondaryMeasure"
              }
            },
            {
              "bind": {
                "to": "Tooltip"
              }
            }
          ]
        }
      }
    }
  ],
  "drilldown": {
    "roles": [
      "Category"
    ]
  },
  "supportsHighlight": true,
  "suppressDefaultTitle": true,
  "supportsMultiVisualSelection": true,
